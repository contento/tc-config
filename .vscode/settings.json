{
  "files.associations": {
    "*.BAR": "ini",
    "*.INI": "ini",
    "WINCMD.INI": "ini",
    "tcignore.txt": "plaintext"
  },
  "editor.rulers": [120],
  "files.encoding": "windows1252",
  "files.eol": "\r\n",
  "[powershell]": {
    "editor.tabSize": 4,
    "editor.insertSpaces": true
  },
  "[ini]": {
    "editor.tabSize": 4
  }
}
